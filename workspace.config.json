{
  "project": {
    "display_name": "Flow SDD Orchestrator Boilerplate",
    "root_repo": "sdd-workspace-boilerplate",
    "workflow": {
      "default_orchestrator": "bmad",
      "force_orchestrator": true
    }
  },
  "repos": {
    "sdd-workspace-boilerplate": {
      "path": ".",
      "kind": "root",
      "slice_prefix": "root",
      "compose_service": "workspace",
      "target_roots": [
        "AGENTS.md",
        "README.md",
        "TODO.md",
        "gateway",
        "flow",
        "templates",
        "specs",
        "docs",
        ".tessl",
        ".github",
        "scripts",
        "flowctl",
        "capabilities",
        "runtimes",
        "workspace.capabilities.json",
        "workspace.config.json",
        "workspace.providers.json",
        "workspace.runtimes.json",
        "workspace.secrets.json",
        "workspace.skills.json",
        "workspace.stack.json",
        "tessl.json",
        "Makefile"
      ],
      "default_targets": [
        "../../specs/**/*.spec.md",
        "../../docs/**/*.md",
        "../../flow",
        "../../workspace.config.json",
        "../../workspace.stack.json"
      ]
    }
  },
  "gateway": {
    "transforms": {
      "github": [
        {
          "op": "strip_prefix",
          "field": "title",
          "prefix": "[bot] "
        }
      ],
      "slack": [],
      "jira": []
    },
    "feedback_templates": {
      "workflow.intake": "Task `{task_id}` intent=`{intent}` status=`{status}`\n{body}"
    },
    "spec_inbound_lint": {
      "reject_on_error": false
    }
  },
  "examples": {
    "project_release_deploy": {
      "legacy-api": {
        "deploy": {
          "provider": "github-actions",
          "providers_by_env": {
            "staging": "github-actions",
            "production": "github-actions"
          },
          "env": {
            "FLOW_DEPLOY_GITHUB_REPO": "acme/legacy-api",
            "FLOW_DEPLOY_GITHUB_WORKFLOW": "promotion-pr.yml",
            "FLOW_DEPLOY_GITHUB_REF": "main"
          },
          "env_by_env": {
            "staging": {
              "FLOW_DEPLOY_SOURCE_REF": "main",
              "FLOW_DEPLOY_RUN_MIGRATIONS": "true"
            },
            "production": {
              "FLOW_DEPLOY_SOURCE_REF": "staging"
            }
          }
        }
      }
    }
  }
}

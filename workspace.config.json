{
  "project": {
    "display_name": "Flow SDD Orchestrator Boilerplate",
    "root_repo": "sdd-workspace-boilerplate",
    "workflow": {
      "default_orchestrator": "bmad",
      "force_orchestrator": true
    }
  },
  "repos": {
    "sdd-workspace-boilerplate": {
      "path": ".",
      "kind": "root",
      "slice_prefix": "root",
      "compose_service": "workspace",
      "target_roots": [
        ".gitignore",
        "AGENTS.md",
        "CURSOR.md",
        "OPENCODE.md",
        "opencode.json",
        "README.md",
        "TODO.md",
        ".agents",
        ".cursor",
        ".devcontainer",
        ".mcp.example.json",
        ".flow/memory",
        "gateway",
        "flow",
        "templates",
        "specs",
        "docs",
        ".tessl",
        ".github",
        "scripts",
        "flowctl",
        "capabilities",
        "runtimes",
        "workspace.capabilities.json",
        "workspace.config.json",
        "workspace.providers.json",
        "workspace.runtimes.json",
        "workspace.secrets.json",
        "workspace.skills.json",
        "workspace.stack.json",
        "tessl.json",
        "Makefile"
      ],
      "default_targets": [
        "../../specs/**/*.spec.md",
        "../../docs/**/*.md",
        "../../flow",
        "../../workspace.config.json",
        "../../workspace.stack.json"
      ]
    }
  },
  "gateway": {
    "execution": {
      "auto_plan": false
    },
    "transforms": {
      "github": [
        {
          "op": "strip_prefix",
          "field": "title",
          "prefix": "[bot] "
        }
      ],
      "slack": [],
      "jira": []
    },
    "feedback_templates": {
      "workflow.intake": "Task `{task_id}` intent=`{intent}` status=`{status}`\n{body}"
    },
    "spec_inbound_lint": {
      "reject_on_error": false
    }
  },
  "memory": {
    "agent": {
      "provider": "engram",
      "project": "softos-sdd-orchestrator",
      "data_dir": ".flow/memory/engram",
      "source_boundary": "consultive"
    },
    "execution": {
      "recall_before_plan": false,
      "save_after_release_publish": false
    }
  },
  "examples": {
    "project_release_deploy": {
      "legacy-api": {
        "deploy": {
          "provider": "github-actions",
          "providers_by_env": {
            "staging": "github-actions",
            "production": "github-actions"
          },
          "promotion_strategy": {
            "mode": "pull_request"
          },
          "contract": {
            "deploy_requires_pr": true,
            "deploy_requires_healthcheck": true,
            "post_deploy_smoke_required": true
          },
          "verify": {
            "mode": "healthcheck",
            "retry": {
              "attempts": 4,
              "backoff_seconds": 5
            }
          },
          "env": {
            "FLOW_DEPLOY_GITHUB_REPO": "acme/legacy-api",
            "FLOW_DEPLOY_GITHUB_WORKFLOW": "promotion-pr.yml",
            "FLOW_DEPLOY_GITHUB_REF": "main"
          },
          "env_by_env": {
            "staging": {
              "FLOW_DEPLOY_SOURCE_REF": "release",
              "FLOW_DEPLOY_RUN_MIGRATIONS": "true"
            },
            "production": {
              "FLOW_DEPLOY_SOURCE_REF": "staging"
            }
          }
        },
        "ci": {
          "install_contract": {
            "mode": "strict",
            "manifest_files": [
              "package.json"
            ],
            "lock_files": [
              "pnpm-lock.yaml"
            ]
          }
        }
      }
    }
  }
}

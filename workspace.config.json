{
  "project": {
    "display_name": "Spec-Driven Workspace Boilerplate",
    "root_repo": "workspace-root"
  },
  "repos": {
    "workspace-root": {
      "path": ".",
      "compose_service": "workspace",
      "kind": "root",
      "repo_strategy": "plain",
      "slice_prefix": "root",
      "default_targets": [
        "../../.devcontainer/**",
        "../../Makefile",
        "../../README.md"
      ],
      "contract_roots": [
        ".devcontainer",
        ".github",
        "docs",
        "flow",
        "flowctl",
        "runtimes",
        "scripts",
        "specs"
      ],
      "test_required_roots": [],
      "target_roots": [
        ".github",
        ".devcontainer",
        ".flow",
        ".gitignore",
        ".gitmodules",
        ".tessl",
        "AGENTS.md",
        "Makefile",
        "README.md",
        "_bmad",
        "docs",
        "flow",
        "flowctl",
        "releases",
        "runtimes",
        "scripts",
        "specs",
        "templates",
        "tessl.json",
        "workspace.config.json",
        "workspace.providers.json",
        "workspace.runtimes.json",
        "workspace.secrets.json",
        "workspace.skills.json"
      ],
      "test_runner": "none"
    }
  }
}

{
  "runtime_kind": "project",
  "target_roots": [
    ".github",
    "AGENTS.md",
    "package.json",
    "pnpm-lock.yaml",
    "src",
    "tests",
    "tsconfig.json"
  ],
  "default_targets": [
    "../../{path}/src/**",
    "../../{path}/tests/**"
  ],
  "test_runner": "pnpm",
  "test_hint": "../../{path}/tests",
  "test_required_roots": [
    "package.json",
    "pnpm-lock.yaml",
    "src",
    "tests",
    "tsconfig.json"
  ],
  "placeholder_dirs": [
    "src",
    "tests"
  ],
  "placeholder_files": {
    "package.json": {
      "name": "{name}",
      "private": true,
      "version": "0.0.0",
      "scripts": {
        "test": "echo \"Error: no test specified\" && exit 1"
      }
    },
    "AGENTS.md": "# Node.js Agent Context\n\nEste repositorio es un proyecto en Node.js.\n"
  },
  "agent_skill_refs": [
    "workspace/softos-spec-definition-playbook",
    "workspace/spec-driven-workspace",
    "workspace/node-core"
  ],
  "ci": {
    "install": ["pnpm", "install"],
    "test": ["pnpm", "test"]
  },
  "compose": {
    "dockerfile": "backend.Dockerfile",
    "mount_target": "/app",
    "working_dir": "/app",
    "command": "sleep infinity",
    "networks": ["{network_name}"]
  },
  "notes": "Runtime base para proyectos Node.js."
}

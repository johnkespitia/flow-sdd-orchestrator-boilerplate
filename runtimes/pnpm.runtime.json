{
  "target_roots": [
    ".github",
    "AGENTS.md",
    "package.json",
    "pnpm-lock.yaml",
    "public",
    "src",
    "tests",
    "tsconfig.json",
    "vite.config.ts",
    "vitest.config.ts"
  ],
  "default_targets": [
    "../../{path}/src/**",
    "../../{path}/public/**",
    "../../{path}/tests/**"
  ],
  "test_runner": "pnpm",
  "test_hint": "../../{path}/tests/...",
  "test_required_roots": [
    "package.json",
    "pnpm-lock.yaml",
    "public",
    "src",
    "tests",
    "tsconfig.json",
    "vite.config.ts",
    "vitest.config.ts"
  ],
  "placeholder_dirs": [
    "public",
    "src",
    "tests"
  ],
  "placeholder_files": {
    "package.json": {
      "name": "{name}",
      "private": true,
      "version": "0.0.0",
      "scripts": {
        "lint": "node -e \"console.log('lint placeholder for {name}')\"",
        "test": "node -e \"console.log('test placeholder for {name}')\"",
        "build": "node -e \"console.log('build placeholder for {name}')\""
      }
    }
  },
  "agent_skill_refs": [
    "workspace/spec-driven-workspace"
  ],
  "ci": {
    "install": [
      "pnpm",
      "install"
    ],
    "lint": [
      "pnpm",
      "lint"
    ],
    "test": [
      "pnpm",
      "test"
    ],
    "build": [
      "pnpm",
      "build"
    ]
  },
  "compose": {
    "dockerfile": "frontend.Dockerfile",
    "mount_target": "/app",
    "working_dir": "/app",
    "command": "sleep infinity",
    "default_port": 5173,
    "networks": [
      "{network_name}"
    ]
  },
  "notes": "Runtime para apps Node/pnpm con contrato de src/public/tests."
}

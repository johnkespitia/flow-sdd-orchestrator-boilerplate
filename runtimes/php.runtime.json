{
  "target_roots": [
    ".github",
    "AGENTS.md",
    "app",
    "artisan",
    "bootstrap",
    "composer.json",
    "config",
    "database",
    "public",
    "resources",
    "routes",
    "tests"
  ],
  "default_targets": [
    "../../{path}/app/**",
    "../../{path}/routes/**",
    "../../{path}/tests/**"
  ],
  "test_runner": "php",
  "test_hint": "../../{path}/tests/...",
  "test_required_roots": [
    "app",
    "artisan",
    "bootstrap",
    "composer.json",
    "config",
    "database",
    "public",
    "resources",
    "routes",
    "tests"
  ],
  "placeholder_dirs": [
    "app",
    "routes",
    "tests"
  ],
  "placeholder_files": {
    "composer.json": {
      "name": "workspace/{name}",
      "type": "project",
      "require": {
        "php": "^8.2"
      }
    }
  },
  "agent_skill_refs": [
    "workspace/spec-driven-workspace"
  ],
  "compose": {
    "dockerfile": "backend.Dockerfile",
    "mount_target": "/app",
    "working_dir": "/app",
    "command": "sleep infinity",
    "environment": {
      "APP_ENV": "local",
      "APP_DEBUG": "true",
      "DB_CONNECTION": "mysql",
      "DB_HOST": "db",
      "DB_PORT": "3306",
      "DB_DATABASE": "app_dev",
      "DB_USERNAME": "app",
      "DB_PASSWORD": "app"
    },
    "depends_on": {
      "db": {
        "condition": "service_healthy"
      }
    },
    "support_services": {
      "db": {
        "image": "mysql:8.0",
        "restart": "unless-stopped",
        "volumes": [
          "workspace-mysql-data:/var/lib/mysql"
        ],
        "environment": {
          "MYSQL_ROOT_PASSWORD": "root",
          "MYSQL_DATABASE": "app_dev",
          "MYSQL_USER": "app",
          "MYSQL_PASSWORD": "app"
        },
        "healthcheck": {
          "test": [
            "CMD",
            "mysqladmin",
            "ping",
            "-h",
            "localhost",
            "-u",
            "root",
            "-proot"
          ],
          "interval": "5s",
          "timeout": "3s",
          "retries": 10
        },
        "networks": [
          "{network_name}"
        ]
      }
    },
    "named_volumes": [
      "workspace-mysql-data"
    ],
    "networks": [
      "{network_name}"
    ]
  },
  "notes": "Runtime para servicios PHP/Laravel con contrato de app, routes y tests."
}

def repo_config(repo: str) -> dict[str, object]:
    return REPO_CONFIG[repo]


def implementation_repos() -> list[str]:
    return [
        repo
        for repo, config in REPO_CONFIG.items()
        if str(config.get("kind", "implementation")) != "root"
    ]


def repo_prefix_examples() -> str:
    prefixes = [f"'{prefix}'" for prefix in REPO_PREFIXES.values()]
    return ", ".join(prefixes)


def repo_slice_prefix(repo: str) -> str:
    configured = str(repo_config(repo).get("slice_prefix", "")).strip()
    if configured:
        return slugify(configured)
    path_name = str(repo_config(repo).get("path", repo)).strip("/.")
    return slugify(path_name or repo)


def utc_now() -> str:
    return datetime.now(timezone.utc).replace(microsecond=0).isoformat()


def slugify(value: str) -> str:
    value = value.strip().lower()
    value = re.sub(r"[^a-z0-9]+", "-", value)
    return value.strip("-")


def require_dirs() -> None:
    for directory in [
        FLOW_ROOT,
        STATE_ROOT,
        PLAN_ROOT,
        REPORT_ROOT,
        FLOW_ROOT / "runs",
        SPECS_ROOT / "000-foundation",
        SPECS_ROOT / "domains",
        FEATURE_SPECS,
        ROOT / "templates",
        ROOT / "docs",
    ]:
        directory.mkdir(parents=True, exist_ok=True)


def repo_root(repo: str) -> Path:
    relative = str(repo_config(repo).get("path", ".")).strip()
    if repo == ROOT_REPO or relative in {"", "."}:
        return ROOT
    return ROOT / relative


def parse_frontmatter(spec_path: Path) -> dict[str, object]:
    text = spec_path.read_text(encoding="utf-8")
    lines = text.splitlines()
    if not lines or lines[0].strip() != "---":
        return {}

    end = None
    for idx in range(1, len(lines)):
        if lines[idx].strip() == "---":
            end = idx
            break

    if end is None:
        return {}

    data: dict[str, object] = {}
    current_key: Optional[str] = None

    for raw_line in lines[1:end]:
        line = raw_line.rstrip()
        match = re.match(r"^([A-Za-z0-9_-]+):\s*(.*)$", line)
        if match:
            key = match.group(1)
            value = match.group(2).strip()
            if value:
                data[key] = value
                current_key = None
            else:
                data[key] = []
                current_key = key
            continue

        if current_key and line.strip().startswith("- "):
            current = data.setdefault(current_key, [])
            if isinstance(current, list):
                current.append(line.strip()[2:].strip())

    return data


def replace_frontmatter_status(spec_path: Path, status: str) -> None:
    text = spec_path.read_text(encoding="utf-8")
    if not text.startswith("---\n"):
        raise SystemExit(f"{spec_path} no tiene frontmatter YAML.")

    parts = text.split("---\n", 2)
    if len(parts) < 3:
        raise SystemExit(f"{spec_path} tiene frontmatter invalido.")

    frontmatter = parts[1]
    body = parts[2]
    if re.search(r"^status:\s*.+$", frontmatter, flags=re.MULTILINE):
        frontmatter = re.sub(
            r"^status:\s*.+$",
            f"status: {status}",
            frontmatter,
            count=1,
            flags=re.MULTILINE,
        )
    else:
        frontmatter += f"status: {status}\n"
    spec_path.write_text(f"---\n{frontmatter}---\n{body}", encoding="utf-8")


def rel(path: Path) -> str:
    return path.relative_to(ROOT).as_posix()


def state_path(slug: str) -> Path:
    return STATE_ROOT / f"{slug}.json"


def read_state(slug: str) -> dict[str, object]:
    path = state_path(slug)
    if not path.exists():
        return {}
    return json.loads(path.read_text(encoding="utf-8"))


def write_state(slug: str, payload: dict[str, object]) -> None:
    payload["updated_at"] = utc_now()
    state_path(slug).write_text(json.dumps(payload, indent=2, ensure_ascii=True) + "\n", encoding="utf-8")


def classify_routed_path(raw_path: str) -> tuple[str, str]:
    value = raw_path.strip()
    if not value:
        raise ValueError("Se encontro una ruta vacia en la spec.")

    for repo, prefix in REPO_PREFIXES.items():
        if value.startswith(prefix):
            relative = value[len(prefix) :]
            break
    else:
        if not value.startswith("../../"):
            configured_prefixes = repo_prefix_examples()
            raise ValueError(
                f"Ruta invalida '{raw_path}': debe empezar con '../../', "
                f"o alguno de los prefijos configurados: {configured_prefixes}."
            )
        repo = ROOT_REPO
        relative = value[len("../../") :]

    relative = relative.strip("/")
    if not relative:
        raise ValueError(f"Ruta invalida '{raw_path}': falta la ruta relativa despues del repo.")

    top_level = Path(relative).parts[0]
    if top_level not in TARGET_ROOTS[repo]:
        allowed = ", ".join(sorted(TARGET_ROOTS[repo]))
        raise ValueError(
            f"Ruta invalida '{raw_path}': '{top_level}' no es un root permitido para {repo}. "
            f"Roots permitidos: {allowed}."
        )

    return repo, relative.replace("\\", "/")


def collect_routed_paths(paths: list[str]) -> tuple[dict[str, list[dict[str, str]]], list[str]]:
    indexed: dict[str, list[dict[str, str]]] = {}
    errors: list[str] = []

    for raw_path in paths:
        try:
            repo, relative = classify_routed_path(raw_path)
        except ValueError as exc:
            errors.append(str(exc))
            continue

        indexed.setdefault(repo, []).append({"raw": raw_path, "relative": relative})

    return indexed, errors


def require_routed_paths(paths: list[str], label: str) -> dict[str, list[dict[str, str]]]:
    if not paths:
        raise SystemExit(f"La spec debe declarar al menos un {label}.")

    indexed, errors = collect_routed_paths(paths)
    if errors:
        joined = "\n".join(f"- {error}" for error in errors)
        raise SystemExit(f"{label.capitalize()} invalidos:\n{joined}")

    return indexed


def extract_test_references(text: str) -> list[str]:
    return TEST_REF_RE.findall(text)


def count_todos(text: str) -> int:
    return len(TODO_RE.findall(text))


def render_test_plan_hints(repos: list[str]) -> str:
    lines: list[str] = []
    for repo in repos:
        hint = TEST_HINTS.get(repo)
        if hint:
            lines.append(f"- `[@test] {hint}`")

    if not lines:
        lines.append("- Evidencia de verificacion del workspace: review manual o check operativo.")

    return "\n".join(lines)


def analyze_spec(spec_path: Path) -> dict[str, object]:
    text = spec_path.read_text(encoding="utf-8")
    frontmatter = parse_frontmatter(spec_path)
    targets = list(frontmatter.get("targets", []))
    target_index, target_errors = collect_routed_paths(targets)
    test_refs = extract_test_references(text)
    test_index, test_errors = collect_routed_paths(test_refs)
    missing_frontmatter = [field for field in REQUIRED_FRONTMATTER_FIELDS if not frontmatter.get(field)]

    return {
        "text": text,
        "frontmatter": frontmatter,
        "targets": targets,
        "target_index": target_index,
        "target_errors": target_errors,
        "test_refs": test_refs,
        "test_index": test_index,
        "test_errors": test_errors,
        "todo_count": count_todos(text),
        "missing_frontmatter": missing_frontmatter,
    }


def ensure_spec_ready_for_approval(spec_path: Path) -> dict[str, object]:
    analysis = analyze_spec(spec_path)
    blockers: list[str] = []
    frontmatter = analysis["frontmatter"]

    for field in analysis["missing_frontmatter"]:
        blockers.append(f"Falta el campo de frontmatter `{field}`.")

    blockers.extend(str(error) for error in analysis["target_errors"])
    blockers.extend(str(error) for error in analysis["test_errors"])

    description = str(frontmatter.get("description", "")).strip().lower()
    if not description or description.startswith("todo"):
        blockers.append("`description` debe describir el resultado observable sin placeholders.")

    if analysis["todo_count"]:
        blockers.append("La spec aun contiene `TODO`; cierralos antes de aprobar.")

    target_index = analysis["target_index"]
    test_index = analysis["test_index"]
    implementation_repos = [repo for repo in target_index if repo != ROOT_REPO]
    missing_repo_tests = [repo for repo in implementation_repos if not test_index.get(repo)]
    if missing_repo_tests:
        blockers.append(
            "Faltan referencias `[@test]` para: " + ", ".join(sorted(missing_repo_tests)) + "."
        )

    if blockers:
        joined = "\n".join(f"- {blocker}" for blocker in blockers)
        raise SystemExit(f"La spec no esta lista para aprobar:\n{joined}")

    return analysis


def load_plan_and_slice(slug: str, slice_name: str) -> tuple[dict[str, object], dict[str, object], Path]:
    plan_path = PLAN_ROOT / f"{slug}.json"
    if not plan_path.exists():
        raise SystemExit(f"No existe plan para '{slug}'. Ejecuta `python3 ./flow plan {slug}` primero.")

    plan = json.loads(plan_path.read_text(encoding="utf-8"))
    slices = plan.get("slices", [])
    selected = next((item for item in slices if item["name"] == slice_name), None)
    if selected is None:
        raise SystemExit(f"No existe la slice '{slice_name}' en {rel(plan_path)}.")

    return plan, selected, plan_path


def git_changed_files(repo_path: Path) -> tuple[list[str], Optional[str]]:
    result = subprocess.run(
        ["git", "-C", str(repo_path), "status", "--porcelain"],
        capture_output=True,
        text=True,
        check=False,
    )
    if result.returncode != 0:
        stderr = result.stderr.strip() or "git status fallo"
        return [], stderr

    changed: set[str] = set()
    for line in result.stdout.splitlines():
        if len(line) < 4:
            continue
        raw_path = line[3:].strip()
        path = raw_path.split(" -> ", 1)[-1].strip()
        if path:
            absolute = repo_path / path
            if absolute.is_dir():
                for nested in absolute.rglob("*"):
                    if nested.is_file():
                        changed.add(nested.relative_to(repo_path).as_posix())
                continue
            changed.add(path)

    return sorted(changed), None


def matches_any_pattern(path: str, patterns: list[str]) -> bool:
    normalized = path.replace("\\", "/")
    return any(fnmatch.fnmatch(normalized, pattern) for pattern in patterns)


def materialize_test_paths(repo_path: Path, patterns: list[str]) -> tuple[list[str], list[str]]:
    materialized: list[str] = []
    missing: list[str] = []

    for pattern in patterns:
        candidate = repo_path / pattern
        if candidate.exists():
            materialized.append(pattern)
            continue

        matches = sorted(
            path.relative_to(repo_path).as_posix()
            for path in repo_path.glob(pattern)
            if path.is_file() or path.is_dir()
        )
        if matches:
            materialized.extend(matches)
            continue

        missing.append(pattern)

    return sorted(dict.fromkeys(materialized)), missing


def detect_test_command(repo: str, repo_path: Path, test_paths: list[str]) -> Optional[list[str]]:
    if not test_paths:
        return None

    runner = str(repo_config(repo).get("test_runner", "none")).strip().lower()

    if runner == "php":
        artisan = repo_path / "artisan"
        if artisan.exists():
            return ["php", "artisan", "test", *test_paths]

        phpunit = repo_path / "vendor" / "bin" / "phpunit"
        if phpunit.exists():
            return [str(phpunit), *test_paths]

    if runner == "pnpm":
        package_json = repo_path / "package.json"
        if package_json.exists() and shutil.which("pnpm"):
            try:
                package = json.loads(package_json.read_text(encoding="utf-8"))
            except json.JSONDecodeError:
                return None

            scripts = package.get("scripts", {})
            if isinstance(scripts, dict) and "test" in scripts:
                return ["pnpm", "test", "--", *test_paths]

    return None


def format_findings(findings: list[str]) -> list[str]:
    if not findings:
        return ["- Sin hallazgos."]
    return [f"- {finding}" for finding in findings]


def detect_compose_context() -> dict[str, object]:
    compose_file = DEVCONTAINER_COMPOSE_FILE.resolve()
    context: dict[str, object] = {
        "project": DEFAULT_COMPOSE_PROJECT,
        "files": [compose_file],
        "active": False,
    }

    if not shutil.which("docker"):
        return context

    result = subprocess.run(
        ["docker", "compose", "ls", "--format", "json"],
        capture_output=True,
        text=True,
        check=False,
    )
    if result.returncode != 0 or not result.stdout.strip():
        return context

    try:
        payload = json.loads(result.stdout)
    except json.JSONDecodeError:
        return context

    if not isinstance(payload, list):
        return context

    for entry in payload:
        if not isinstance(entry, dict):
            continue
        config_files = [
            Path(raw_path).resolve()
            for raw_path in str(entry.get("ConfigFiles", "")).split(",")
            if raw_path
        ]
        if compose_file in config_files:
            context["project"] = str(entry.get("Name") or DEFAULT_COMPOSE_PROJECT)
            context["files"] = config_files or [compose_file]
            context["active"] = True
            return context

    return context


def compose_base_command() -> list[str]:
    context = detect_compose_context()
    return ["docker", "compose", "-p", str(context["project"]), "-f", str(DEVCONTAINER_COMPOSE_FILE.resolve())]


def tty_enabled() -> bool:
    return sys.stdin.isatty() and sys.stdout.isatty()


def running_inside_workspace() -> bool:
    workspace_root = WORKSPACE_PATH.rstrip("/")
    root_path = ROOT.as_posix()
    return root_path == workspace_root or root_path.startswith(f"{workspace_root}/")


def compose_exec_args(
    service: str,
    interactive: Optional[bool] = None,
    workdir: Optional[str] = None,
) -> list[str]:
    use_tty = tty_enabled() if interactive is None else interactive
    args = ["exec"]
    if not use_tty:
        args.append("-T")
    if workdir:
        args.extend(["-w", workdir])
    args.append(service)
    return args


def run_compose(extra_args: list[str], interactive: Optional[bool] = None) -> int:
    command = compose_base_command() + extra_args
    try:
        return subprocess.run(command, cwd=ROOT, check=False).returncode
    except FileNotFoundError as exc:
        raise SystemExit("No encontre `docker` en PATH para operar el stack del workspace.") from exc


def normalize_passthrough(args: list[str]) -> list[str]:
    if args and args[0] == "--":
        return args[1:]
    return args


def run_workspace_tool(tool_args: list[str], interactive: Optional[bool] = None) -> int:
    return run_compose(
        compose_exec_args(WORKSPACE_SERVICE, interactive=interactive, workdir=WORKSPACE_PATH) + tool_args,
        interactive,
    )


def workspace_executable_available(executable: str) -> bool:
    if running_inside_workspace():
        return shutil.which(executable) is not None

    command = compose_base_command() + compose_exec_args(
        WORKSPACE_SERVICE,
        interactive=False,
        workdir=WORKSPACE_PATH,
    )
    command.extend(["sh", "-lc", f"command -v {shlex.quote(executable)} >/dev/null 2>&1"])
    try:
        result = subprocess.run(command, cwd=ROOT, check=False)
    except FileNotFoundError:
        return False
    return result.returncode == 0


def bmad_command_prefix() -> list[str]:
    explicit = env_first("FLOW_BMAD_COMMAND", "PLG_BMAD_COMMAND")
    if explicit is not None:
        command_prefix = shlex.split(explicit)
        if not command_prefix:
            raise SystemExit("`FLOW_BMAD_COMMAND`/`PLG_BMAD_COMMAND` esta vacio; configura el comando BMAD primero.")
        return command_prefix

    for candidate in (["bmad"], ["bmad-method"], ["npx", "bmad-method"]):
        if workspace_executable_available(candidate[0]):
            return candidate

    raise SystemExit(
        "No encontre un runtime BMAD en el workspace. "
        "Rebuild del devcontainer para instalar `bmad-method`, o ajusta `FLOW_BMAD_COMMAND`."
    )


def command_stack_doctor(_: argparse.Namespace) -> int:
    context = detect_compose_context()
    docker_ok = shutil.which("docker") is not None

    print(f"{PROJECT_NAME} stack doctor")
    print(f"- docker_cli: {'ok' if docker_ok else 'missing'}")
    print(f"- compose_file: {DEVCONTAINER_COMPOSE_FILE.resolve()}")
    print(f"- compose_project: {context['project']}")
    print(f"- compose_active: {'yes' if context['active'] else 'no'}")
    print(f"- workspace_service: {WORKSPACE_SERVICE}")
    return 0 if docker_ok else 1


def command_stack_ps(_: argparse.Namespace) -> int:
    return run_compose(["ps"])


def command_stack_up(args: argparse.Namespace) -> int:
    command = ["up", "-d"]
    if args.build:
        command.append("--build")
    return run_compose(command)


def command_stack_down(args: argparse.Namespace) -> int:
    command = ["down"]
    if args.volumes:
        command.append("-v")
    if args.rmi_local:
        command.extend(["--rmi", "local"])
    return run_compose(command)


def command_stack_build(args: argparse.Namespace) -> int:
    command = ["build"]
    if args.no_cache:
        command.append("--no-cache")
    return run_compose(command)


def command_stack_logs(args: argparse.Namespace) -> int:
    command = ["logs"]
    if args.follow:
        command.append("-f")
    if args.service:
        command.append(args.service)
    return run_compose(command, interactive=args.follow)


def command_stack_sh(args: argparse.Namespace) -> int:
    service = args.service or WORKSPACE_SERVICE
    workdir = WORKSPACE_PATH if service == WORKSPACE_SERVICE else None
    return run_compose(
        compose_exec_args(service, interactive=True, workdir=workdir) + [args.shell],
        interactive=True,
    )


def command_stack_exec(args: argparse.Namespace) -> int:
    command = normalize_passthrough(args.command)
    if not command:
        raise SystemExit("Debes indicar un comando despues del servicio. Ejemplo: `flow stack exec backend -- php artisan about`.")
    interactive = not args.no_tty
    workdir = WORKSPACE_PATH if args.service == WORKSPACE_SERVICE else None
    return run_compose(
        compose_exec_args(args.service, interactive=interactive, workdir=workdir) + command,
        interactive=interactive,
    )


def run_local_tool(tool_args: list[str]) -> int:
    try:
        return subprocess.run(tool_args, cwd=ROOT, check=False).returncode
    except FileNotFoundError as exc:
        raise SystemExit(f"No encontre el ejecutable `{tool_args[0]}`.") from exc


def command_tessl(args: argparse.Namespace) -> int:
    passthrough = normalize_passthrough(args.args) or ["--help"]
    if running_inside_workspace():
        return run_local_tool(["tessl", *passthrough])
    return run_workspace_tool(["tessl", *passthrough])


def command_bmad(args: argparse.Namespace) -> int:
    command_prefix = bmad_command_prefix()
    passthrough = normalize_passthrough(args.args) or ["--help"]
    full_command = [*command_prefix, *passthrough]

    if running_inside_workspace():
        return run_local_tool(full_command)

    return run_workspace_tool(full_command)


def resolve_spec(identifier: str) -> Path:
    raw = Path(identifier)
    if raw.exists():
        return raw.resolve()

    slug = slugify(raw.stem.replace(".spec", ""))
    candidates = list(SPECS_ROOT.rglob(f"{slug}.spec.md"))
    if not candidates:
        raise SystemExit(f"No encontre una spec para '{identifier}'.")
    return candidates[0]


def spec_slug(spec_path: Path) -> str:
    return spec_path.name.replace(".spec.md", "")


def render_targets(repos: list[str]) -> str:
    lines: list[str] = []
    for repo in repos:
        for target in DEFAULT_TARGETS[repo]:
            lines.append(f"  - {target}")
    return "\n".join(lines)


def command_doctor(_: argparse.Namespace) -> int:
    stack_context = detect_compose_context()
    bmad_available = False
    bmad_command = "unresolved"
    try:
        prefix = bmad_command_prefix()
        bmad_available = True
        bmad_command = " ".join(prefix)
    except SystemExit:
        pass

    checks: dict[str, bool] = {
        "devcontainer": ROOT.joinpath(".devcontainer").is_dir(),
        "tessl_root": ROOT.joinpath(".tessl").is_dir(),
        "tessl_json": ROOT.joinpath("tessl.json").is_file(),
        "workspace_config": WORKSPACE_CONFIG_FILE.is_file(),
        "specs_root": SPECS_ROOT.is_dir(),
        "flow_state": FLOW_ROOT.is_dir(),
        "templates": ROOT.joinpath("templates").is_dir(),
        "docker_cli": shutil.which("docker") is not None,
    }
    for repo in REPO_NAMES:
        checks[f"repo_{slugify(repo).replace('-', '_')}"] = repo_root(repo).is_dir()

    print(f"{PROJECT_NAME} flow doctor")
    for key, ok in checks.items():
        print(f"- {key}: {'ok' if ok else 'missing'}")

    missing = [name for name, ok in checks.items() if not ok]
    if missing:
        print(f"\nFaltan rutas requeridas: {', '.join(missing)}", file=sys.stderr)
        return 1

    print(f"\nWorkspace root: {ROOT}")
    print(f"Worktree root sugerido: {WORKTREE_ROOT}")
    print(f"Workspace mount path: {WORKSPACE_PATH}")
    print(f"Compose project: {stack_context['project']}")
    print(f"Compose activo: {'yes' if stack_context['active'] else 'no'}")
    print(f"BMAD CLI: {'ok' if bmad_available else 'missing'}")
    print(f"BMAD command: {bmad_command}")
    print(f"BMAD project: {'ok' if ROOT.joinpath('_bmad').is_dir() else 'missing'}")
    if running_inside_workspace():
        print(f"Tessl runtime local: {'ok' if shutil.which('tessl') else 'missing'}")
    return 0



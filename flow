    if not command:
        raise SystemExit("Debes indicar un comando despues del servicio. Ejemplo: `flow stack exec backend -- php artisan about`.")
    interactive = not args.no_tty
    workdir = WORKSPACE_PATH if args.service == WORKSPACE_SERVICE else None
    return run_compose(
        compose_exec_args(args.service, interactive=interactive, workdir=workdir) + command,
        interactive=interactive,
    )


def run_local_tool(tool_args: list[str]) -> int:
    try:
        return subprocess.run(tool_args, cwd=ROOT, check=False).returncode
    except FileNotFoundError as exc:
        raise SystemExit(f"No encontre el ejecutable `{tool_args[0]}`.") from exc


def command_tessl(args: argparse.Namespace) -> int:
    passthrough = normalize_passthrough(args.args) or ["--help"]
    if running_inside_workspace():
        return run_local_tool(["tessl", *passthrough])
    return run_workspace_tool(["tessl", *passthrough])


def command_bmad(args: argparse.Namespace) -> int:
    command_prefix = bmad_command_prefix()
    passthrough = normalize_passthrough(args.args) or ["--help"]
    full_command = [*command_prefix, *passthrough]

    if running_inside_workspace():
        return run_local_tool(full_command)

    return run_workspace_tool(full_command)


def serialize_skill_entry(entry: dict[str, object]) -> dict[str, object]:
    payload = {
        "name": entry["name"],
        "provider": entry["provider"],
        "kind": entry["kind"],
        "source": entry["source"],
        "enabled": entry["enabled"],
        "required": entry["required"],
        "sync": entry["sync"],
        "args": entry["args"],
        "notes": entry["notes"],
    }
    local_source_path = entry.get("local_source_path")
    if isinstance(local_source_path, Path):
        payload["local_source_path"] = rel(local_source_path)
    else:
        payload["local_source_path"] = None
    return payload


def command_skills_doctor(_: argparse.Namespace) -> int:
    args = _
    payload = load_skills_config()
    entries, errors = skills_entries(payload)
    findings = list(errors)

    provider_names = {str(entry["provider"]) for entry in entries}
    for provider in payload.get("providers", {}).keys():
        try:
            provider_names.add(normalize_skill_provider(str(provider)))
        except ValueError as exc:
            findings.append(str(exc))

    data = {
        "manifest": SKILLS_CONFIG_FILE.name,
        "providers": [],
        "entries": [],
        "findings": findings,
    }

    for provider in sorted(provider_names):
        enabled = skills_provider_enabled(payload, provider)
        runtime_ok = skills_provider_runtime_available(provider)
        status = "ok" if runtime_ok or not enabled else "missing"
        data["providers"].append({"name": provider, "status": status, "enabled": enabled})
        if enabled and not runtime_ok:
            findings.append(f"El runtime del proveedor `{provider}` no esta disponible.")

    for entry in entries:
        local_source_path = entry.get("local_source_path")
        origin = rel(local_source_path) if isinstance(local_source_path, Path) else str(entry["source"])
        state = "enabled" if entry["enabled"] else "disabled"
        sync_mode = "sync" if entry["sync"] else "manual"
        data["entries"].append(
            {
                "name": entry["name"],
                "state": state,
                "sync_mode": sync_mode,
                "provider": entry["provider"],
                "kind": entry["kind"],
                "origin": origin,
            }
        )
        if entry["required"] and not entry["enabled"]:
            findings.append(f"`{entry['name']}` es requerida pero esta deshabilitada.")
        if entry["provider"] == "tessl" and entry["kind"] == "skill" and local_source_path is None:
            findings.append(
                f"`{entry['name']}` requiere un source local relativo al workspace para `tessl skill import`."
            )

    data["findings"] = findings
    if wants_json(args):
        print(json_dumps(data))
        return 1 if findings else 0

    print("Skills doctor")
    print(f"- manifest: {'ok' if SKILLS_CONFIG_FILE.is_file() else 'missing'} ({SKILLS_CONFIG_FILE.name})")
    for provider in data["providers"]:
        print(f"- provider {provider['name']}: {provider['status']} ({'enabled' if provider['enabled'] else 'disabled'})")
    for entry in data["entries"]:
        print(
            f"- entry {entry['name']}: {entry['state']}, {entry['sync_mode']}, "
            f"{entry['provider']}, {entry['kind']} -> {entry['origin']}"
        )
    if findings:
        print("", file=sys.stderr)
        for finding in findings:
            print(f"- {finding}", file=sys.stderr)
        return 1
    return 0



def render_runtime_file(content: object, repo_name: str) -> str:
    if isinstance(content, dict):
        text = json.dumps(content, indent=2, ensure_ascii=True) + "\n"
    else:
        text = str(content)
    return text.replace("{name}", repo_name)


def load_compose_text() -> str:
    if not DEVCONTAINER_COMPOSE_FILE.is_file():
        raise SystemExit(f"Falta {rel(DEVCONTAINER_COMPOSE_FILE)}.")
    return DEVCONTAINER_COMPOSE_FILE.read_text(encoding="utf-8")


def write_compose_text(text: str) -> None:
    DEVCONTAINER_COMPOSE_FILE.write_text(text, encoding="utf-8")


def infer_compose_network_name(compose_text: str) -> str:
    match = re.search(r"^networks:\n(?:\s*\n)*  ([A-Za-z0-9_-]+):\s*$", compose_text, flags=re.MULTILINE)
    if match:
        return match.group(1)
    return "workspace"


def compose_service_exists(compose_text: str, service_name: str) -> bool:
    return re.search(rf"^  {re.escape(service_name)}:\s*$", compose_text, flags=re.MULTILINE) is not None


def extract_service_block(compose_text: str, service_name: str) -> str:
    start = re.search(rf"^  {re.escape(service_name)}:\n", compose_text, flags=re.MULTILINE)
    if not start:
        return ""

    remainder = compose_text[start.end() :]
    next_service = re.search(r"^  [A-Za-z0-9_-]+:\n", remainder, flags=re.MULTILINE)
    next_volumes = re.search(r"^volumes:\n", remainder, flags=re.MULTILINE)
    cut_points = [match.start() for match in [next_service, next_volumes] if match]
    end = min(cut_points) if cut_points else len(remainder)
    return remainder[:end]


def extract_service_scalar(block: str, key: str, default: str) -> str:
    match = re.search(rf"^\s+{re.escape(key)}:\s*(.+?)\s*$", block, flags=re.MULTILINE)
    if not match:
        return default
    return match.group(1).strip().strip('"').strip("'")


def extract_service_mount_target(block: str, default: str) -> str:
    match = re.search(
        r"^\s+- \.\./[^:]+:(?P<target>[^:\n]+)(?::[A-Za-z]+)?\s*$",
        block,
        flags=re.MULTILINE,
    )
    if not match:
        return default
    return match.group("target").strip()


def infer_runtime_service_settings(compose_text: str, runtime: str) -> dict[str, object]:
    if runtime == "php":
        block = extract_service_block(compose_text, runtime_template_service("php"))
        return {
            "dockerfile": extract_service_scalar(block, "dockerfile", "backend.Dockerfile"),
            "working_dir": extract_service_scalar(block, "working_dir", "/app"),
            "command": extract_service_scalar(block, "command", "sleep infinity"),
            "mount_target": extract_service_mount_target(block, "/app"),
            "environment": {
                "APP_ENV": extract_service_scalar(block, "APP_ENV", "local"),
                "APP_DEBUG": extract_service_scalar(block, "APP_DEBUG", "true"),
                "DB_CONNECTION": extract_service_scalar(block, "DB_CONNECTION", "mysql"),
                "DB_HOST": extract_service_scalar(block, "DB_HOST", "db"),
                "DB_PORT": extract_service_scalar(block, "DB_PORT", "3306"),
                "DB_DATABASE": extract_service_scalar(block, "DB_DATABASE", "app_dev"),
                "DB_USERNAME": extract_service_scalar(block, "DB_USERNAME", "app"),
                "DB_PASSWORD": extract_service_scalar(block, "DB_PASSWORD", "app"),
            },
        }

    if runtime == "pnpm":
        block = extract_service_block(compose_text, runtime_template_service("pnpm"))
        return {
            "dockerfile": extract_service_scalar(block, "dockerfile", "frontend.Dockerfile"),
            "working_dir": extract_service_scalar(block, "working_dir", "/app"),
            "command": extract_service_scalar(block, "command", "sleep infinity"),
            "mount_target": extract_service_mount_target(block, "/app"),
        }

    raise SystemExit(f"No conozco el runtime `{runtime}`.")


def render_compose_service(
    service_name: str,
    repo_path: str,
    runtime: str,
    port: Optional[int],
    network_name: str,
    compose_text: str,
) -> str:
    template = RUNTIME_DEFAULTS[runtime]["compose_template"]
    if template is None:
        raise SystemExit(f"El runtime `{runtime}` no tiene template de servicio Compose.")

    if template == "php":
        settings = infer_runtime_service_settings(compose_text, "php")
        env = settings["environment"]
        lines = [
            f"  # ── Added project: {service_name} ({runtime}) ───────────────────────────",
            f"  {service_name}:",
            "    build:",
            "      context: .",
            f"      dockerfile: {settings['dockerfile']}",
            "    volumes:",
            f"      - ../{repo_path}:{settings['mount_target']}:cached",
            f"    working_dir: {settings['working_dir']}",
            f"    command: {settings['command']}",
        ]
        if port:
            lines.extend(["    ports:", f'      - "{port}:{port}"'])
        lines.extend(
            [
                "    environment:",
                f"      APP_ENV: {env['APP_ENV']}",
                f'      APP_DEBUG: "{env["APP_DEBUG"]}"',
                f"      DB_CONNECTION: {env['DB_CONNECTION']}",
                f"      DB_HOST: {env['DB_HOST']}",
                f'      DB_PORT: "{env["DB_PORT"]}"',
                f"      DB_DATABASE: {env['DB_DATABASE']}",
                f"      DB_USERNAME: {env['DB_USERNAME']}",
                f"      DB_PASSWORD: {env['DB_PASSWORD']}",
                "    depends_on:",
                "      db:",
                "        condition: service_healthy",
                "    networks:",
                f"      - {network_name}",
            ]
        )
        return "\n".join(lines) + "\n\n"

    if template == "pnpm":
        settings = infer_runtime_service_settings(compose_text, "pnpm")
        lines = [
            f"  # ── Added project: {service_name} ({runtime}) ───────────────────────────",
            f"  {service_name}:",
            "    build:",
            "      context: .",
            f"      dockerfile: {settings['dockerfile']}",
            "    volumes:",
            f"      - ../{repo_path}:{settings['mount_target']}:cached",
            f"    working_dir: {settings['working_dir']}",
            f"    command: {settings['command']}",
        ]
        if port:
            lines.extend(["    ports:", f'      - "{port}:{port}"'])
        lines.extend(
            [
                "    networks:",
                f"      - {network_name}",
            ]
        )
        return "\n".join(lines) + "\n\n"

    raise SystemExit(f"No conozco el template Compose `{template}`.")


def add_service_to_compose(service_name: str, repo_path: str, runtime: str, port: Optional[int]) -> None:
    compose_text = load_compose_text()
    if compose_service_exists(compose_text, service_name):
        raise SystemExit(f"El servicio `{service_name}` ya existe en {rel(DEVCONTAINER_COMPOSE_FILE)}.")

    comment_marker = re.search(r"\n  # [^\n]*\n  db:\n", compose_text)
    service_marker = re.search(r"\n  db:\n", compose_text)
    volumes_marker = re.search(r"\nvolumes:\n", compose_text)
    insertion_match = comment_marker or service_marker or volumes_marker
    if insertion_match is None:
        raise SystemExit(f"No pude encontrar un punto de insercion valido en {rel(DEVCONTAINER_COMPOSE_FILE)}.")

    network_name = infer_compose_network_name(compose_text)
    service_block = render_compose_service(service_name, repo_path, runtime, port, network_name, compose_text)
    head = compose_text[: insertion_match.start()].rstrip("\n")
    tail = compose_text[insertion_match.start() :].lstrip("\n")
    updated = f"{head}\n\n{service_block}{tail}"
    write_compose_text(updated)



def env_first(*names: str, default: Optional[str] = None) -> Optional[str]:
    for name in names:
        value = os.environ.get(name)
        if value is not None:
            return value
    return default


def load_workspace_config() -> dict[str, object]:
    if not WORKSPACE_CONFIG_FILE.is_file():
        raise SystemExit(f"Falta {WORKSPACE_CONFIG_FILE.name} en el root del workspace.")

    try:
        data = json.loads(WORKSPACE_CONFIG_FILE.read_text(encoding="utf-8"))
    except json.JSONDecodeError as exc:
        raise SystemExit(f"{WORKSPACE_CONFIG_FILE.name} no contiene JSON valido: {exc}") from exc

    if not isinstance(data, dict):
        raise SystemExit(f"{WORKSPACE_CONFIG_FILE.name} debe contener un objeto JSON en el root.")

    project = data.get("project")
    repos = data.get("repos")
    if not isinstance(project, dict) or not isinstance(repos, dict) or not repos:
        raise SystemExit(f"{WORKSPACE_CONFIG_FILE.name} debe definir `project` y `repos`.")

    root_repo = project.get("root_repo")
    if not isinstance(root_repo, str) or root_repo not in repos:
        raise SystemExit(f"{WORKSPACE_CONFIG_FILE.name} debe declarar `project.root_repo` presente en `repos`.")

    return data



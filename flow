def env_first(*names: str, default: Optional[str] = None) -> Optional[str]:
    for name in names:
        value = os.environ.get(name)
        if value is not None:
            return value
    return default


def load_workspace_config() -> dict[str, object]:
    if not WORKSPACE_CONFIG_FILE.is_file():
        raise SystemExit(f"Falta {WORKSPACE_CONFIG_FILE.name} en el root del workspace.")

    try:
        data = json.loads(WORKSPACE_CONFIG_FILE.read_text(encoding="utf-8"))
    except json.JSONDecodeError as exc:
        raise SystemExit(f"{WORKSPACE_CONFIG_FILE.name} no contiene JSON valido: {exc}") from exc

    if not isinstance(data, dict):
        raise SystemExit(f"{WORKSPACE_CONFIG_FILE.name} debe contener un objeto JSON en el root.")

    project = data.get("project")
    repos = data.get("repos")
    if not isinstance(project, dict) or not isinstance(repos, dict) or not repos:
        raise SystemExit(f"{WORKSPACE_CONFIG_FILE.name} debe definir `project` y `repos`.")

    root_repo = project.get("root_repo")
    if not isinstance(root_repo, str) or root_repo not in repos:
        raise SystemExit(f"{WORKSPACE_CONFIG_FILE.name} debe declarar `project.root_repo` presente en `repos`.")

    return data


WORKSPACE_CONFIG = load_workspace_config()
PROJECT_CONFIG = WORKSPACE_CONFIG["project"]
REPO_CONFIG = WORKSPACE_CONFIG["repos"]
PROJECT_NAME = str(PROJECT_CONFIG.get("display_name") or ROOT.name)
ROOT_REPO = str(PROJECT_CONFIG["root_repo"])
REPO_NAMES = list(REPO_CONFIG)
DEFAULT_COMPOSE_PROJECT = env_first("FLOW_COMPOSE_PROJECT", "PLG_COMPOSE_PROJECT", default=f"{ROOT.name}_devcontainer")
WORKSPACE_SERVICE = env_first("FLOW_WORKSPACE_SERVICE", "PLG_WORKSPACE_SERVICE", default="workspace") or "workspace"
WORKSPACE_PATH = env_first("FLOW_WORKSPACE_PATH", "PLG_WORKSPACE_PATH", default="/workspace") or "/workspace"
WORKTREE_ROOT = Path(
    env_first("FLOW_WORKTREE_ROOT", "PLG_WORKTREE_ROOT", default=str(ROOT / ".worktrees")) or (ROOT / ".worktrees")
).expanduser()

DEFAULT_TARGETS = {
    repo: list(config.get("default_targets", []))
    for repo, config in REPO_CONFIG.items()
}

TARGET_ROOTS = {
    repo: set(config.get("target_roots", []))
    for repo, config in REPO_CONFIG.items()
}

REPO_PREFIXES = {
    repo: f"../../{config['path'].strip('/')}/"
    for repo, config in REPO_CONFIG.items()
    if repo != ROOT_REPO and str(config.get("path", ".")).strip("/") not in {"", "."}
}

TEST_HINTS = {
    repo: str(config["test_hint"])
    for repo, config in REPO_CONFIG.items()
    if config.get("test_hint")
}

REQUIRED_FRONTMATTER_FIELDS = ("name", "description", "status", "owner", "targets")
TEST_REF_RE = re.compile(r"\[@test\]\s+([^\s`]+)")
TODO_RE = re.compile(r"\bTODO\b")

STATE_ORDER = [
    "idea",
    "draft-spec",
    "reviewing-spec",
    "approved-spec",
    "planned",

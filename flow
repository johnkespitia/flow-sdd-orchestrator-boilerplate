def select_spec_paths(
    spec_identifier: Optional[str] = None,
    *,
    all_specs: bool = False,
    changed: bool = False,
    base: Optional[str] = None,
    head: Optional[str] = None,
) -> list[Path]:
    if spec_identifier:
        return [resolve_spec(spec_identifier)]

    if all_specs:
        return all_spec_paths()

    if changed:
        changed_files, error = git_diff_name_only(ROOT, base=base, head=head)
        if error:
            raise SystemExit(f"No pude resolver specs cambiadas: {error}")
        spec_paths = [
            (ROOT / relative_path).resolve()
            for relative_path in changed_files
            if relative_path.endswith(".spec.md") and (ROOT / relative_path).exists()
        ]
        return sorted(dict.fromkeys(spec_paths))

    return all_spec_paths()



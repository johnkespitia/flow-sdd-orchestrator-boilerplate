    if not isinstance(payload, dict):
        raise SystemExit(f"{PROVIDERS_CONFIG_FILE.name} debe contener un objeto JSON en el root.")

    for category in ["release", "infra"]:
        section = payload.get(category)
        if not isinstance(section, dict):
            raise SystemExit(f"{PROVIDERS_CONFIG_FILE.name} debe definir la seccion `{category}`.")

def command_release_promote(args: argparse.Namespace) -> int:
    manifest = load_release_manifest(args.version)
    if args.environment in {"staging", "production"} and not args.approver:
        raise SystemExit("`--approver` es obligatorio para staging y production.")

    hook = release_hook(args.environment)
    promotion_payload = {
        "version": args.version,
        "environment": args.environment,
        "promoted_at": utc_now(),
        "approver": args.approver,
        "status": "recorded",
        "hook": rel(hook) if hook else None,
    }

    if hook:
        env = os.environ.copy()
        env["FLOW_RELEASE_VERSION"] = args.version
        env["FLOW_RELEASE_ENV"] = args.environment
        env["FLOW_RELEASE_MANIFEST"] = str(release_manifest_path(args.version).resolve())
        execution = subprocess.run(
            ["bash", str(hook.resolve())],
            cwd=ROOT,
            env=env,
            capture_output=True,
            text=True,
            check=False,
        )
        combined = (execution.stdout + "\n" + execution.stderr).strip()
        promotion_payload["output_tail"] = "\n".join(combined.splitlines()[-40:]) if combined else ""
        if execution.returncode != 0:
            promotion_payload["status"] = "failed"
            write_json(release_promotion_path(args.version, args.environment), promotion_payload)
            raise SystemExit(f"La promocion `{args.environment}` fallo con `{rel(hook)}`.")

        promotion_payload["status"] = "executed"

    promotions = manifest.setdefault("promotions", [])
    if isinstance(promotions, list):
        promotions.append(promotion_payload)
    write_json(release_manifest_path(args.version), manifest)
    write_json(release_promotion_path(args.version, args.environment), promotion_payload)

    if args.environment == "production":
        for feature in manifest.get("features", []):
            slug = str(feature.get("slug", ""))
            if not slug:
                continue
            state = read_state(slug)
            if not state:
                continue
            state["status"] = "released"
            state["released_in"] = args.version
            write_state(slug, state)

    print(rel(release_promotion_path(args.version, args.environment)))
    return 0



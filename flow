def detect_compose_context() -> dict[str, object]:
    compose_file = compose_control_file().resolve()
    context: dict[str, object] = {
        "project": DEFAULT_COMPOSE_PROJECT,
        "files": [compose_file],
        "active": False,
    }

    if not shutil.which("docker"):
        return context

    result = subprocess.run(
        ["docker", "compose", "ls", "--format", "json"],
        capture_output=True,
        text=True,
        check=False,
    )
    if result.returncode != 0 or not result.stdout.strip():
        return context

    try:
        payload = json.loads(result.stdout)
    except json.JSONDecodeError:
        return context

    if not isinstance(payload, list):
        return context

    for entry in payload:
        if not isinstance(entry, dict):
            continue
        config_files = [
            Path(raw_path).resolve()
            for raw_path in str(entry.get("ConfigFiles", "")).split(",")
            if raw_path
        ]
        if compose_file in config_files:
            context["project"] = str(entry.get("Name") or DEFAULT_COMPOSE_PROJECT)
            context["files"] = config_files or [compose_file]
            context["active"] = True
            return context

    if running_inside_workspace():
        for entry in payload:
            if not isinstance(entry, dict):
                continue
            if str(entry.get("Name") or "") != str(context["project"]):
                continue
            config_files = [
                Path(raw_path).resolve()
                for raw_path in str(entry.get("ConfigFiles", "")).split(",")
                if raw_path
            ]
            context["files"] = config_files or context["files"]
            context["active"] = True
            return context

    return context


def compose_base_command() -> list[str]:
    context = detect_compose_context()
    return [
        "docker",
        "compose",
        "-p",
        str(context["project"]),
        "--project-directory",
        str(compose_control_file().resolve().parent),
        "-f",
        str(compose_control_file().resolve()),
    ]


def tty_enabled() -> bool:
    return sys.stdin.isatty() and sys.stdout.isatty()


def running_inside_workspace() -> bool:
    workspace_root = WORKSPACE_PATH.rstrip("/")
    root_path = ROOT.as_posix()
    return root_path == workspace_root or root_path.startswith(f"{workspace_root}/")


def compose_control_root() -> Path:
    if running_inside_workspace():
        return HOST_ROOT_HINT
    return ROOT


def compose_control_file() -> Path:
    return compose_control_root() / ".devcontainer" / "docker-compose.yml"


def compose_exec_args(
    service: str,
    interactive: Optional[bool] = None,
    workdir: Optional[str] = None,
) -> list[str]:
    use_tty = tty_enabled() if interactive is None else interactive
    args = ["exec"]
    if not use_tty:
        args.append("-T")
    if workdir:
        args.extend(["-w", workdir])
    args.append(service)
    return args


def run_compose(extra_args: list[str], interactive: Optional[bool] = None) -> int:
    command = compose_base_command() + extra_args
    try:
        return subprocess.run(command, cwd=compose_control_root(), check=False).returncode
    except FileNotFoundError as exc:
        raise SystemExit("No encontre `docker` en PATH para operar el stack del workspace.") from exc


def capture_compose(extra_args: list[str]) -> dict[str, object]:
    command = compose_base_command() + extra_args
    try:
        result = subprocess.run(
            command,
            cwd=compose_control_root(),
            capture_output=True,
            text=True,
            check=False,
        )
    except FileNotFoundError as exc:
        raise SystemExit("No encontre `docker` en PATH para operar el stack del workspace.") from exc

    combined = (result.stdout + "\n" + result.stderr).strip()
    tail = "\n".join(combined.splitlines()[-40:]) if combined else ""
    return {
        "command": command,
        "returncode": result.returncode,
        "output_tail": tail,
        "stdout": result.stdout,
    }


def normalize_passthrough(args: list[str]) -> list[str]:
    if args and args[0] == "--":
        return args[1:]
    return args


def run_workspace_tool(tool_args: list[str], interactive: Optional[bool] = None) -> int:
    return run_compose(
        compose_exec_args(WORKSPACE_SERVICE, interactive=interactive, workdir=WORKSPACE_PATH) + tool_args,
        interactive,
    )


def workspace_executable_available(executable: str) -> bool:
    if running_inside_workspace():
        return shutil.which(executable) is not None

    command = compose_base_command() + compose_exec_args(
        WORKSPACE_SERVICE,
        interactive=False,
        workdir=WORKSPACE_PATH,
    )
    command.extend(["sh", "-lc", f"command -v {shlex.quote(executable)} >/dev/null 2>&1"])
    try:
        result = subprocess.run(command, cwd=ROOT, check=False)
    except FileNotFoundError:
        return False
    return result.returncode == 0


def bmad_command_prefix() -> list[str]:
    explicit = env_first("FLOW_BMAD_COMMAND", "PLG_BMAD_COMMAND")
    if explicit is not None:
        command_prefix = shlex.split(explicit)
        if not command_prefix:
            raise SystemExit("`FLOW_BMAD_COMMAND`/`PLG_BMAD_COMMAND` esta vacio; configura el comando BMAD primero.")
        return command_prefix

    for candidate in (["bmad"], ["bmad-method"], ["npx", "bmad-method"]):
        if workspace_executable_available(candidate[0]):
            return candidate

    raise SystemExit(
        "No encontre un runtime BMAD en el workspace. "
        "Rebuild del devcontainer para instalar `bmad-method`, o ajusta `FLOW_BMAD_COMMAND`."
    )



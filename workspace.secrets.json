{
  "default_provider": "env",
  "providers": {
    "env": {
      "enabled": true,
      "entrypoint": "scripts/providers/secrets/env.sh",
      "requires": []
    },
    "op": {
      "enabled": false,
      "entrypoint": "scripts/providers/secrets/op.sh",
      "requires": [
        "op"
      ]
    },
    "sops": {
      "enabled": false,
      "entrypoint": "scripts/providers/secrets/sops.sh",
      "requires": [
        "sops"
      ]
    }
  },
  "targets": {
    "devcontainer_env": {
      "path": ".devcontainer/.env.generated",
      "format": "dotenv",
      "provider": "env",
      "items": {
        "SOFTOS_GATEWAY_API_TOKEN": "env:SOFTOS_GATEWAY_API_TOKEN",
        "SOFTOS_SLACK_SIGNING_SECRET": "env:SOFTOS_SLACK_SIGNING_SECRET",
        "SOFTOS_SLACK_WEBHOOK_URL": "env:SOFTOS_SLACK_WEBHOOK_URL",
        "SOFTOS_GITHUB_WEBHOOK_SECRET": "env:SOFTOS_GITHUB_WEBHOOK_SECRET",
        "SOFTOS_GITHUB_TOKEN": "env:SOFTOS_GITHUB_TOKEN",
        "SOFTOS_JIRA_WEBHOOK_TOKEN": "env:SOFTOS_JIRA_WEBHOOK_TOKEN",
        "SOFTOS_JIRA_BASE_URL": "env:SOFTOS_JIRA_BASE_URL",
        "SOFTOS_JIRA_USER_EMAIL": "env:SOFTOS_JIRA_USER_EMAIL",
        "SOFTOS_JIRA_API_TOKEN": "env:SOFTOS_JIRA_API_TOKEN",
        "SOFTOS_DEFAULT_FEEDBACK_PROVIDER": "env:SOFTOS_DEFAULT_FEEDBACK_PROVIDER"
      }
    }
  }
}
